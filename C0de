#define VIBR_FULL_SPEED   255
#define VIBR_CRUISE_SPEED 127

#define ADXL_SCALE     0.0078f 
#define MPU_SCALE      4096.0f  

#define CALIB_SAMPLES  100      

float adxl1_offset = 0;
float adxl2_offset = 0;
float mpu_offset   = 0;  

