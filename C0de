// -------------------------------------------------------
// Mux helper
// -------------------------------------------------------
void selectMuxChannel(uint8_t ch) {
  if (ch > 7) return;
  Wire.beginTransmission(MUX_ADDR);
  Wire.write(1 << ch);
  Wire.endTransmission();
}

// -------------------------------------------------------
// ADXL345 helpers
// -------------------------------------------------------
void initADXL(uint8_t addr) {
  Wire.beginTransmission(addr);
  Wire.write(0x2D);
  Wire.write(0x08);
  Wire.endTransmission();

  Wire.beginTransmission(addr);
  Wire.write(0x31);
  Wire.write(0x02);
  Wire.endTransmission();
}

bool readADXL_raw(uint8_t addr, int16_t &rz) {
  Wire.beginTransmission(addr);
  Wire.write(0x36);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(addr, (uint8_t)2);
  if (Wire.available() < 2) return false;
  rz = Wire.read() | (Wire.read() << 8);
  return true;
}

bool readADXL(uint8_t addr, float offset, float &z) {
  int16_t rz;
  if (!readADXL_raw(addr, rz)) return false;
  z = (rz - offset) * ADXL_SCALE;
  return true;
}

float calibrateADXL(uint8_t addr) {
  long sum = 0;
  int  good = 0;
  for (int i = 0; i < CALIB_SAMPLES; i++) {
    int16_t rz;
    if (readADXL_raw(addr, rz)) {
      sum += rz;
      good++;
    }
    delay(5);
  }
  float offset = good > 0 ? (float)sum / good : 0;
  offset -= (1.0f / ADXL_SCALE);
  return offset;
}

// -------------------------------------------------------
// Motor / relay control
// -------------------------------------------------------
void setMotor(int i, bool on, int spd = -1) {
  int EN[4]   = {ENA1, ENB1, ENA2, ENB2};
  int IN_A[4] = {IN1_1, IN3_1, IN1_2, IN3_2};
  int IN_B[4] = {IN2_1, IN4_1, IN2_2, IN4_2};
  if (spd >= 0) motorSpeed[i] = spd;
  motorState[i] = on;
  if (on) {
    digitalWrite(IN_A[i], HIGH);
    digitalWrite(IN_B[i], LOW);
    analogWrite(EN[i], motorSpeed[i]);
  } else {
    digitalWrite(IN_A[i], LOW);
    digitalWrite(IN_B[i], LOW);
    analogWrite(EN[i], 0);
  }
  motorStatePrev[i] = on;

  if (i == 2) {
    if (spd >= 0) motorSpeed[3] = motorSpeed[2];
    setMotor(3, on, motorSpeed[2]);
  }
}

void setRelay(int i, bool on) {
  relayState[i] = on;
  digitalWrite(i == 0 ? RELAY1 : RELAY2, on ? HIGH : LOW);
  relayStatePrev[i] = on;
}

void allOff() {
  for (int i = 0; i < 4; i++) setMotor(i, false);
  for (int i = 0; i < 2; i++) setRelay(i, false);
}

