// -------------------------------------------------------
// Phase management
// -------------------------------------------------------
void enterPhase(Phase p) {
  currentPhase      = p;
  phaseStartTime    = millis();
  screenNeedsRedraw = true;

  switch (p) {
    case TAXI:
      allOff();
      setMotor(0, true);
      setMotor(1, true, VIBR_FULL_SPEED);
      setRelay(0, true);
      break;
    case ASCENT:
      allOff();
      setMotor(1, true, VIBR_FULL_SPEED);
      setMotor(2, true); 
      break;
    case CRUISE:
      allOff();
      setMotor(1, true, VIBR_CRUISE_SPEED);
      setMotor(2, true); 
      break;
    case DESCENT:
      allOff();
      setMotor(1, true, VIBR_FULL_SPEED);
      setMotor(0, true);
      setRelay(0, true);
      break;
    case COMPLETE:
      allOff();
      drawArrivalScreen();
      break;
    default:
      break;
  }
}

void startAutomation() {
  enterPhase(TAXI);
}

void stopAutomation() {
  allOff();
  currentPhase      = IDLE;
  screenNeedsRedraw = true;
}

// -------------------------------------------------------
// Automation logic
// -------------------------------------------------------
void runAutomation() {
  unsigned long elapsed = millis() - phaseStartTime;

  switch (currentPhase) {
    case TAXI:
      if (!isnan(currentRH)) {
        if (currentRH > 95.0) {
          if (motorState[0])  { setMotor(0, false); setRelay(0, false); }
        } else {
          if (!motorState[0]) { setMotor(0, true);  setRelay(0, true);  }
        }
      }
      if (elapsed >= TAXI_DURATION) enterPhase(ASCENT);
      break;

    case ASCENT:
      if (elapsed >= ASCENT_DURATION) enterPhase(CRUISE);
      break;

    case CRUISE:
      if (elapsed >= CRUISE_DURATION) enterPhase(DESCENT);
      break;

    case DESCENT:
      if (!isnan(currentRH) && currentRH >= 95.0) {
        enterPhase(COMPLETE);
      } else if (elapsed >= DESCENT_TIMEOUT) {
        enterPhase(COMPLETE);
      } else {
        if (!motorState[0]) { setMotor(0, true); setRelay(0, true); }
      }
      break;

    default:
      break;
  }
}

// -------------------------------------------------------
// Serial handler
// -------------------------------------------------------
void handleSerial() {
  static String buffer = "";
  while (Serial.available() > 0) {
    char c = Serial.read();
    if (c == '\n' || c == '\r') {
      if (buffer.length() == 1) {
        char cmd = buffer.charAt(0);
        if (cmd == ' ') {
          if (currentPhase == IDLE || currentPhase == COMPLETE) startAutomation();
          else                      stopAutomation();
        } else if (currentPhase == IDLE) {
          if      (cmd == '1') motorState[0] = !motorState[0];
          else if (cmd == '2') motorState[1] = !motorState[1];
          else if (cmd == '3') motorState[2] = !motorState[2];
          else if (cmd == '4') motorState[3] = !motorState[3];
          else if (cmd == '5') relayState[0] = !relayState[0];
          else if (cmd == '6') relayState[1] = !relayState[1];
        }
      } else if (buffer.length() >= 2 && currentPhase == IDLE) {
        char cmd = buffer.charAt(0);
        int  val = constrain(buffer.substring(1).toInt(), 0, 255);
        int  idx = -1;
        if      (cmd=='A'||cmd=='a') idx=0;
        else if (cmd=='B'||cmd=='b') idx=1;
        else if (cmd=='C'||cmd=='c') idx=2;
        else if (cmd=='D'||cmd=='d') idx=3;
        if (idx >= 0) {
          motorSpeed[idx] = val;
        }
      }
      buffer = "";
    } else {
      buffer += c;
    }
  }
}

// -------------------------------------------------------
// TFT helpers
// -------------------------------------------------------
void drawPill(int x, int y, const char* name, bool on, int spd = -1) {
  uint16_t bg  = on ? C_DKGREEN : C_GRAY;
  uint16_t txt = on ? C_WHITE   : 0xC618;
  tft.fillRoundRect(x, y, 108, 28, 6, bg);
  tft.drawRoundRect(x, y, 108, 28, 6, on ? C_GREEN : C_GRAY);
  tft.setTextColor(txt);
  tft.setTextSize(1);
  tft.setCursor(x + 5, y + 5);
  tft.print(name);
  if (on && spd >= 0) {
    tft.setCursor(x + 5, y + 15);
    tft.print(String(map(spd, 0, 255, 0, 100)) + "%");
  }
}

void printSensorRow(int x, int y, int w, float temp, float rh, uint16_t rhCol = C_WHITE) {
  tft.fillRect(x, y, w, 22, C_BLACK);
  tft.setTextSize(2);
  tft.setTextColor(C_WHITE);
  tft.setCursor(x, y);
  tft.print(isnan(temp) ? "ERR" : String(temp, 1) + "C");
  tft.print("  ");
  tft.setTextColor(rhCol);
  tft.print(isnan(rh) ? "ERR" : String(rh, 1) + "%");
}

