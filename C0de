void updateIdleScreen() {
  tft.setTextSize(2);
  int x = 160, w = 310;
  tft.fillRect(x, 10, w, 22, C_BLACK);
  tft.setTextColor(C_WHITE);
  tft.setCursor(x, 10);
  for (int i = 0; i < 4; i++) tft.print(motorState[i] ? "ON " : "OFF ");

  tft.fillRect(x, 50, w, 22, C_BLACK);
  tft.setTextColor(C_WHITE);
  tft.setCursor(x, 50);
  for (int i = 0; i < 4; i++) { tft.print(motorSpeed[i]); tft.print(" "); }

  tft.fillRect(x, 90, w, 22, C_BLACK);
  tft.setTextColor(C_WHITE);
  tft.setCursor(x, 90);
  for (int i = 0; i < 2; i++) tft.print(relayState[i] ? "ON " : "OFF ");

  printSensorRow(x, 130, w, currentTemp, currentRH);
  printSensorRow(x, 160, w, currentTemp1, currentRH1);

  float az1 = 0;
  readADXL(ADXL1_ADDR, adxl1_offset, az1);
  tft.fillRect(x, 190, w, 22, C_BLACK);
  tft.setTextColor(C_WHITE);
  tft.setCursor(x, 190);
  tft.print(az1, 3); tft.print("g");

  float az2 = 0;
  selectMuxChannel(1);
  readADXL(ADXL2_ADDR, adxl2_offset, az2);
  tft.fillRect(x, 220, w, 22, C_BLACK);
  tft.setTextColor(C_WHITE);
  tft.setCursor(x, 220);
  tft.print(az2, 3); tft.print("g");
}

const char* phaseName(Phase p) {
  switch (p) {
    case TAXI:    return "TAXI";
    case ASCENT:  return "ASCENT";
    case CRUISE:  return "CRUISE";
    case DESCENT: return "DESCENT";
    default:      return "---";
  }
}

uint16_t phaseColor(Phase p) {
  switch (p) {
    case TAXI:    return C_YELLOW;
    case ASCENT:  return C_GREEN;
    case CRUISE:  return C_BLUE;
    case DESCENT: return C_ORANGE;
    default:      return C_WHITE;
  }
}

void drawAutoScreenSkeleton() {
  tft.fillScreen(C_BLACK);
  tft.fillRect(0, 0, SCREEN_W, 50, 0x1082);
  tft.drawRect(0, 0, SCREEN_W, 50, C_GRAY);
  tft.setTextSize(3);
  tft.setTextColor(phaseColor(currentPhase));
  tft.setCursor(10, 12);
  tft.print(phaseName(currentPhase));
  tft.setTextColor(C_CYAN);
  tft.setTextSize(2);
  tft.setCursor(10,  58); tft.print("Time left:");
  tft.setCursor(10,  88); tft.print("Ambient:");
  tft.setCursor(10, 118); tft.print("Internal:");
  tft.setCursor(10, 148); tft.print("Components:");
  tft.drawFastHLine(0, 143, SCREEN_W, C_GRAY);
  tft.setTextColor(C_GRAY);
  tft.setTextSize(1);
  tft.setCursor(10, 308);
  tft.print("SPACE = stop automation");
}

void updateAutoScreen() {
  uint16_t pcol = phaseColor(currentPhase);
  if (currentPhase != prevDisplayPhase) {
    tft.fillRect(10, 12, 300, 30, 0x1082);
    tft.setTextSize(3);
    tft.setTextColor(pcol);
    tft.setCursor(10, 12);
    tft.print(phaseName(currentPhase));
    prevDisplayPhase = currentPhase;
  }
  unsigned long dur = 0;
  if      (currentPhase == TAXI)   dur = TAXI_DURATION;
  else if (currentPhase == ASCENT) dur = ASCENT_DURATION;
  else if (currentPhase == CRUISE) dur = CRUISE_DURATION;
  else if (currentPhase == DESCENT) dur = DESCENT_TIMEOUT;

  unsigned long elapsed = millis() - phaseStartTime;
  uint32_t remaining = (elapsed < dur) ? (dur - elapsed) / 1000 : 0;

  if (remaining != prevRemaining) {
    tft.fillRect(160, 58, 200, 22, C_BLACK);
    tft.setTextColor(pcol);
    tft.setTextSize(2);
    tft.setCursor(160, 58);
    int mins = remaining / 60;
    int secs = remaining % 60;
    if (mins > 0) { tft.print(mins); tft.print("m "); }
    tft.print(secs); tft.print("s");
    prevRemaining = remaining;
  }

  printSensorRow(160, 88, 180, currentTemp, currentRH);
  printSensorRow(160, 118, 180, currentTemp1, currentRH1);

  // ACCELEROMETER DATA: A2 on top, A1 on bottom, renamed "Vibr"
  float az1 = 0, az2 = 0;
  readADXL(ADXL1_ADDR, adxl1_offset, az1);
  selectMuxChannel(1);
  readADXL(ADXL2_ADDR, adxl2_offset, az2);
  
  tft.setTextSize(2); tft.setTextColor(C_WHITE);
  tft.fillRect(350, 88, 120, 50, C_BLACK);
  tft.setCursor(350, 88);  tft.print("Vibr:"); tft.print(az2, 2); // A2 now on top
  tft.setCursor(350, 118); tft.print("Vibr:"); tft.print(az1, 2); // A1 now on bottom

  int px = 10, py = 158, gap = 115;
  const char* mnames[4] = {"Pump", "Vibr", "Vacp", "M4"};
  for (int i = 0; i < 4; i++) {
    int spd = (i == 1) ? motorSpeed[1] : -1;
    drawPill(px + i * gap, py, mnames[i], motorState[i], spd);
    prevMotor[i] = motorState[i];
  }
  const char* rnames[2] = {"Rly1", "Rly2"};
  for (int i = 0; i < 2; i++) {
    drawPill(px + i * gap, py + 35, rnames[i], relayState[i]);
    prevRelay[i] = relayState[i];
  }
}

void setup() {
  Serial.begin(115200);
  Wire.begin();
  pinMode(ENA1,  OUTPUT); pinMode(ENB1,  OUTPUT);
  pinMode(IN1_1, OUTPUT); pinMode(IN2_1, OUTPUT);
  pinMode(IN3_1, OUTPUT); pinMode(IN4_1, OUTPUT);
  pinMode(ENA2,  OUTPUT); pinMode(ENB2,  OUTPUT);
  pinMode(IN1_2, OUTPUT); pinMode(IN2_2, OUTPUT);
  pinMode(IN3_2, OUTPUT); pinMode(IN4_2, OUTPUT);
  pinMode(RELAY1, OUTPUT);
  pinMode(RELAY2, OUTPUT);

  uint16_t ID = tft.readID();
  tft.begin(ID);
  tft.setRotation(3);
  tft.fillScreen(C_BLACK);
  tft.setCursor(10, 10);
  tft.print("Initializing Rig...");

  initADXL(ADXL1_ADDR);
  selectMuxChannel(1);
  initADXL(ADXL2_ADDR);
  selectMuxChannel(0);
  sht31.begin(SHT_ADDR);
  selectMuxChannel(1);
  sht31.begin(SHT_ADDR);

  adxl1_offset = calibrateADXL(ADXL1_ADDR);
  selectMuxChannel(1);
  adxl2_offset = calibrateADXL(ADXL2_ADDR);

  drawIdleScreen();
}

void loop() {
  handleSerial();
  if (millis() - lastSensorRead >= sensorReadInterval) {
    lastSensorRead = millis();
    selectMuxChannel(0);
    currentRH   = sht31.readHumidity();
    currentTemp = sht31.readTemperature();
    selectMuxChannel(1);
    currentRH1   = sht31.readHumidity();
    currentTemp1 = sht31.readTemperature();
  }

  if (currentPhase != IDLE && currentPhase != COMPLETE) runAutomation();
  if (currentPhase == IDLE) { motorUpdate(); relayUpdate(); }

  if (millis() - lastDisplay >= displayInterval) {
    lastDisplay = millis();
    if (screenNeedsRedraw) {
      if (currentPhase == IDLE) drawIdleScreen();
      else if (currentPhase == COMPLETE) drawArrivalScreen();
      else                      drawAutoScreenSkeleton();
      screenNeedsRedraw = false;
    }
    if (currentPhase == IDLE) updateIdleScreen();
    else if (currentPhase != COMPLETE) updateAutoScreen();
  }
}

void motorUpdate() {
  int EN[4]   = {ENA1, ENB1, ENA2, ENB2};
  int IN_A[4] = {IN1_1, IN3_1, IN1_2, IN3_2};
  int IN_B[4] = {IN2_1, IN4_1, IN2_2, IN4_2};
  for (int i = 0; i < 4; i++) {
    if (i == 3) continue;
    if (motorState[i] != motorStatePrev[i] || motorSpeed[i] != motorSpeedPrev[i]) {
      setMotor(i, motorState[i], motorSpeed[i]);
      motorSpeedPrev[i] = motorSpeed[i]; 
    }
  }
}

void relayUpdate() {
  int REL[2] = {RELAY1, RELAY2};
  for (int i = 0; i < 2; i++) {
    if (relayState[i] != relayStatePrev[i]) {
      digitalWrite(REL[i], relayState[i] ? HIGH : LOW);
      relayStatePrev[i] = relayState[i];
    }
  }
}
